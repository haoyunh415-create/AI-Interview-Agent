.idea/

*.md
!README.md
!DEPLOYMENT.md

tests/

*.tmp.*

# Frontend (not needed for backend Docker image)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/test-results/
frontend/playwright-report/
frontend/e2e/

# Auto-generated JWT secret
.jwt_secret.key
