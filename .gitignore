# 忽略 API 密钥和环境变量
.env
.env.local
# 但保留 .env.example（模板文件）
!.env.example

# 自动生成的 JWT 密钥（首次启动生成）
.jwt_secret.key

# 忽略 Python 缓存
__pycache__/
*.pyc
.pytest_cache/

# 忽略本地数据库和向量库
*.db
chroma_db/

# 忽略虚拟环境
.venv/
venv/

# 忽略 IDE 配置
.vscode/
.idea/

# 忽略模型文件（体积过大，运行时下载）
models/

# 忽略临时编辑文件
*.tmp.*
*/.tmp.*

# 忽略生成的报告
outputs/reports/*.pdf

# 数据库备份
backups/

# Dependencies
node_modules/
frontend/node_modules/

# Build output
.next/
frontend/.next/
frontend/out/
frontend/test-results/
frontend/playwright-report/

# IDE
.vscode/
.idea/

# Data directory (SQLite DB, vector store)
data/

# Coverage and cache
.coverage
.ruff_cache/