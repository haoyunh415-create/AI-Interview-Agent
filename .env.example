# ===========================================
# AI Interview Copilot — Environment Config
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# ── LLM Provider (pick one) ──
LLM_PROVIDER=deepseek          # deepseek | openai | anthropic | ollama

# ── DeepSeek (default) ──
# Get your key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com

# ── OpenAI (when LLM_PROVIDER=openai) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic (when LLM_PROVIDER=anthropic) ──
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Ollama (when LLM_PROVIDER=ollama; no API key needed) ──
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Shared LLM settings ──
# LLM_TEMPERATURE=0.7
# LLM_TIMEOUT=60
# LLM_MAX_RETRIES=2

# ── Paths ──
# CHROMA_DB_PATH=./chroma_db
# DATA_DIR=./data
# MODEL_PATH=./models
# EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# ── Logging ──
# LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ── LLM response cache ──
# LLM_CACHE_TTL=300           # Seconds to cache LLM responses (default 300 = 5 min)
# LLM_CACHE_MAXSIZE=256       # Max number of cached responses

# ── Interview timer (optional countdown per question) ──
# TIMER_ENABLED=false
# TIMER_DURATION=120

# ── JWT Auth ──
# 若不设置，首次启动会自动生成随机密钥并写入 .jwt_secret.key
# 生产环境建议显式设置一个 64 字符以上的随机字符串
# JWT_SECRET=your-64-char-random-secret-here
# JWT_EXPIRY_HOURS=72

# ── Rate limiting ──
# RATE_LIMIT_DEFAULT=30/minute
# RATE_LIMIT_AUTH=5/minute
# RATE_LIMIT_LLM=10/minute

# ── Sentry error tracking (optional) ──
# 设置后自动捕获后端异常并上报到 Sentry。留空则不启用。
# SENTRY_DSN=https://your-dsn@sentry.io/123456

# ── Database ──
# SQLite (default, no setup needed):
#   DB_URL=sqlite:///./data/interview.db
# PostgreSQL (production):
#   DB_URL=postgresql://user:password@localhost:5432/tech_chat
# DB_URL=sqlite:///./data/interview.db

# ── API ──
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8765
